# Raw recordings and parse caches stay local — large and regenerable, never commit.
# The small prebuilt feature matrix (data/processed/featurematrix.npz) IS committed,
# so a machine without the raw recordings can still train and evaluate.
data/raw/
data/interim/
data/external/*
!data/external/.gitkeep

# Generated artifacts — regenerate with the Makefile targets (make train / evaluate).
models/*
!models/.gitkeep
reports/*
!reports/.gitkeep
!reports/figures/
reports/figures/*
!reports/figures/.gitkeep

# marimo notebook session cache (regenerated on run)
__marimo__/

# Flutter-port golden vectors — large, regenerable, kept local.
export/

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# OS / editor / local agent tooling (not part of the project)
.DS_Store
.agents/
skills-lock.json

# Scratch text files (notes, dumps, etc.) — not part of the project
*.txt
